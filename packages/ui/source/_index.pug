mixin display-font
	link(href='https://fonts.googleapis.com/css?family=Asap:400,400i,500,500i,600,600i,700,700i&display=swap' rel='stylesheet')

mixin serif-font
	link(href='https://fonts.googleapis.com/css2?family=Caladea:ital,wght@0,400;0,700;1,400;1,700&display=swap' rel='stylesheet')

mixin landing-cta
	.flex.justify-center.flex-col.items-center(class="sm:flex-row sm:items-start")
		+create-project-btn


		.mx-4.text-gray-500.text-xs.font-medium.my-4 or
		.mailing-reminder-entry
		//- div
			a(href="/app/create-project" class="hover:bg-red-700 hover:text-white").text-xl.font-medium.inline-block.bg-red-600.text-white.rounded.px-8.py-2 Create project
			div.text-sm.text-gray-600.mt-2 Without sign up.

mixin create-project-btn(hideLabel)
	.inline-block.text-center(class=attributes.class)
		//- a(href="/app/create-project" class="hover:bg-red-700 hover:text-white").text-xl.font-medium.inline-block.rounded.px-8.py-2.shadow-md.bg-red-600.text-white Create a project
		a(href="/app/create-project" class="hover:bg-red-700 hover:text-white").text-xl.font-medium.inline-block.rounded.px-8.py-2.shadow-md.bg-red-600.text-white Install now

		unless hideLabel
			div.text-sm.text-gray-600.mt-2 In 2 minutes, literally.

mixin landing-head
	//- Socials
	meta(name='description' content='Gripeless is a tool that encourages website owners to solicit complaints from their users. For free!')
	meta(property='og:title' content='Gripeless — Encourage complaining')
	meta(property='og:description' content='Start capturing complaints with the fastest complaint management solution out there. Crafted specifically for website owners.')
	meta(property='og:url' content='https://usegripeless.com')
	meta(property='og:site_name' content='Gripeless')
	meta(property='og:image' content='https://share.usegripeless.com/social-preview.png')

	meta(name='twitter:card' content='summary_large_image')
	meta(name='twitter:image' content='https://share.usegripeless.com/social-preview.png')


mixin nav
	.mx-4: .max-w-screen-lg.mx-auto
		header.flex.justify-between.items-center.h-24.border-b
			div.flex.items-center
				a.mr-8.flex-none(href="/")
					img.w-32(src="./img/logotype.svg" alt="Gripeless Logotype")
				a.text-gray-700.mr-6.hidden(
					class="hover:text-gray-900 md:block"
					href="/pricing"
				) Pricing
				a.text-gray-700.mr-6.hidden(
					class="hover:text-gray-900 md:block"
					href="/blog"
				) Blog
				a.text-gray-700.mr-6.hidden(
					class="hover:text-gray-900 md:block"
					href="/about"
				) About us
				a.text-gray-700.mr-6.hidden(
					class="hover:text-gray-900 md:block"
					target='_blank'
					href="/docs"
				)
					| Docs
					svg.ml-2.inline-block.w-4.h-4.fill-current.text-gray-700(xmlns='http://www.w3.org/2000/svg', viewBox='0 0 24 24')
						path(d='M19 6.41L8.7 16.71a1 1 0 11-1.4-1.42L17.58 5H14a1 1 0 010-2h6a1 1 0 011 1v6a1 1 0 01-2 0V6.41zM17 14a1 1 0 012 0v5a2 2 0 01-2 2H5a2 2 0 01-2-2V7c0-1.1.9-2 2-2h5a1 1 0 010 2H5v12h12v-5z')

			div
				#app
mixin features
	#features.container.max-w-screen-xl.mx-auto
		mixin checkmark
			.text-xl.font-semibold.bg-teal-300.rounded-full.text-white.w-8.h-8.inline-flex.items-center.justify-center(class!=attributes.class)
				span ✓

		mixin feature(title)
			.px-8.mb-16.w-96(class="lg:w-1/3")
				.flex
					.flex-none.mr-4.mt-1
						+checkmark
					div
						.text-2xl.font-semibold.mb-1= title
						block

		mixin coming-soon
			div.inline-block.px-2.py-1.bg-gray-200.text-xs.font-medium.rounded.mt-4 Coming soon!

		.flex.flex-wrap.justify-center(class="lg:justify-start")
			+feature('Dashboard')
				p See all your gripes in one organised place. Or just use integrations.

			+feature('Notifications for users')
				p Complainers get automatically notified when you fix their issues.

			+feature('Screenshots')
				p They say that a picture says more than a thousand words... make complaining visual!

			+feature('User metadata')
				p See everything relevant about the users' device and the state of your app.

			+feature('Incredibly light')
				p At a weight of #[span.font-bold 40kB compressed] the Javascript SDK adds virtually no performance hit to your site.

			+feature('All devices, all websites')
				p The API is very simple to use and easy to integrate into any framework, or to use without one.

mixin foot
	footer.bg-teal-300.py-16.px-4
		.container.mx-auto.max-w-screen-lg
			.flex.justify-between.flex-col.text-center(class="md:flex-row")
				.mb-8(class="md:mb-0 md:text-left")
					.mb-1: a.text-xl.font-semibold(href='/') Gripeless
					.text-sm.max-w-sm.mb-2.mx-auto(class="md:mx-0").
						Gripeless is a free complaint management solution for
						web apps and Electron apps with the goal of encouraging users to
						report problems which they otherwise wouldn't have
						reported.

					.text-gray-700: a(class="hover:text-gray-900" href="/") Learn more
					.text-gray-700: a(class="hover:text-gray-900" href="/app/create-project") Create a project
					.text-gray-700: a(class="hover:text-gray-900" href='/pricing') Pricing
					.text-gray-700: a(class="hover:text-gray-900" href="/docs") Documentation
					.text-gray-700: a(class="hover:text-gray-900" href='/legal') Terms & Privacy
					.text-gray-700: a(class="hover:text-gray-900" href="mailto:support@usegripeless.com") Support
					button.text-lg.text-gray-700.border.px-4.py-2.rounded.font-medium.mt-4.bg-teal-400.border-teal-500#gripeless-button(
						class="hover:text-gray-900 hover:bg-teal-500 hover:border-teal-600"
					) Report an issue...
				.text-sm(class="md:text-right")
					p.font-bold Primitive Software

mixin post-preview(title, at, description, url)
	a.border.px-4.py-3.mb-2.block.bg-white.font-display(
		href=url
		class='hover:bg-gray-100'
	)
		.text-sm.font-display= at
		.text-lg.font-bold= title
		.mb-1= description
		.text-red-700.text-sm Read more...

mixin landing-script
	script(src="./ts/entries/landing.ts")
