{
  "compilerOptions": {
    "outDir": "dist",
    "lib": ["es2018"],
    "target": "es2018",
    "module": "commonjs",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "declaration": true,
    "moduleResolution": "node",
    "strict": true,
    "noEmitOnError": true,
    "typeRoots": ["./node_modules/@types", "./typings"]
  },
  "include": [
    "source"
  ]
}
