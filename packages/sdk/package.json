{
	"name": "@gripeless/sdk",
	"main": "dist/index.js",
	"version": "1.6.0",
	"types": "dist",
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public"
	},
	"scripts": {
		"build": "yarn clean && NODE_ENV=production rollup -c && yarn size",
		"clean": "del dist",
		"dev": "yarn serve & rollup -c -w",
		"prepublishOnly": "yarn build && cli-confirm \"Publish? [y/N]\"",
		"serve": "node serve.js",
		"size": "gzip -c dist/index.js | wc -c"
	},
	"devDependencies": {
		"@rollup/plugin-commonjs": "^11.0.2",
		"@rollup/plugin-node-resolve": "^7.1.0",
		"@rollup/plugin-replace": "^2.3.1",
		"@wessberg/rollup-plugin-ts": "^1.2.15",
		"cli-confirm": "^1.0.1",
		"del-cli": "^3.0.0",
		"rollup": "^1.31.0",
		"rollup-plugin-elm": "^2.0.2",
		"rollup-plugin-postcss": "^2.0.6",
		"rollup-plugin-string": "^3.0.0",
		"rollup-plugin-terser": "^5.2.0",
		"rollup-plugin-visualizer": "^4.0.4",
		"typescript": "^3.7.5"
	},
	"dependencies": {
		"@gripeless/pico": "^1.0.1",
		"bowser": "^2.9.0"
	}
}
